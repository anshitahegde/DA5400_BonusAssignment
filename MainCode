# Tree assignment

def left(n):  return 2 * n
def right(n): return 2 * n + 1

def _find_branch(b, node):
    for (n, f, th), v in b.items():
        if n == node and v: return f, th
    return None

def _predict_one(b, w, xi):
    n = 1
    for _ in range(30):
        br = _find_branch(b, n)
        if br is None: break
        f, th = br
        n = left(n) if xi[f] <= th else right(n)
    for (nd, k), v in w.items():
        if nd == n and v: return k
    return 0

def predict_tree(b, w, X):
    return np.array([_predict_one(b, w, xi) for xi in X])

def _misclassify_cost(b, w, xi, yi, gamma):
    best = np.inf
    def dfs(node, xi_cur, cost):
        nonlocal best
        if cost >= best: return
        br = _find_branch(b, node)
        if br is None:
            for (nd, k), v in w.items():
                if nd == node and v and k != yi:
                    best = min(best, cost)
            return
        f, th = br
        if xi_cur[f] <= th:
            dfs(left(node), xi_cur, cost)
            xi2 = xi_cur.copy()
            delta = th + 1 - xi_cur[f]
            xi2[f] = th + 1
            dfs(right(node), xi2, cost + gamma[f] * delta)
        else:
            dfs(right(node), xi_cur, cost)
            xi2 = xi_cur.copy()
            delta = xi_cur[f] - th
            xi2[f] = th
            dfs(left(node), xi2, cost + gamma[f] * delta)

    dfs(1, xi.astype(float).copy(), 0.0)
    return best

def _build_cart(X, y, depth):
    clf = DecisionTreeClassifier(max_depth=depth, random_state=0)
    clf.fit(X, y)
    b, w, t = {}, {}, clf.tree_

    def recurse(node, tree_node):
        if t.feature[node] < 0:
            w[(tree_node, int(np.argmax(t.value[node])))] = 1
        else:
            f, th = t.feature[node], int(t.threshold[node])
            b[(tree_node, f, th)] = 1
            recurse(t.children_left[node], left(tree_node))
            recurse(t.children_right[node], right(tree_node))

    recurse(0, 1)
    return b, w

# Tree Core algorithm 

def robust_tree(X_tr, y_tr, depth, gamma, budget, max_iter=10):
    X_cur = X_tr.copy().astype(float)

    for _ in range(max_iter):
        b, w = _build_cart(X_cur, y_tr, depth)
        costs = []
        for i in range(len(y_tr)):
            if _predict_one(b, w, X_cur[i]) == y_tr[i]:
                c = _misclassify_cost(b, w, X_tr[i].astype(float), y_tr[i], gamma)
                costs.append((c, i))
        costs.sort(key=lambda t: t[0])

        used, changed = 0.0, False
        X_new = X_tr.copy().astype(float)
        for c, i in costs:
            if used + c <= budget:
                br = _find_branch(b, 1)
                if br:
                    f, th = br
                    X_new[i, f] = th + 1 if X_new[i, f] <= th else th
                used += c
                changed = True

        if not changed: break
        X_cur = X_new

    return b, w

# Evaluation Mechanics

def perturb_X(X, gamma, budget, n=300):
    rng = np.random.default_rng(0)
    out = []
    for _ in range(n):
        Xp = X.copy().astype(float)
        rem = budget
        for f in range(X.shape[1]):
            if rem <= 0 or gamma[f] == 0: continue
            max_d = int(rem / gamma[f])
            if max_d < 1: continue
            d = rng.integers(-max_d, max_d + 1)
            Xp[:, f] += d
            rem -= gamma[f] * abs(d)
        out.append(Xp)
    return out

def evaluate(predict_fn, X_te, y_te, gamma, budget):
    perturbed = perturb_X(X_te, gamma, budget)
    accs = [np.mean(predict_fn(Xp) == y_te) for Xp in perturbed]
    nom = predict_fn(X_te)
    return {
        "worst_case_acc": float(np.min(accs)),
        "avg_acc": float(np.mean(accs)),
        "f1": float(f1_score(y_te, nom, average="weighted", zero_division=0)),
    }

